# =============================================================================
# MWP Pipeline - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For Modal deployment, set these as Modal secrets (see docs/setup.md).

# --- Required ---

# Google Gemini API key (for transcription, planning, script generation, review, polish, metadata)
GEMINI_API_KEY=

# Fal AI API key (for cover art image generation)
FAL_KEY=

# PostgreSQL connection string (Neon or any PostgreSQL with pgvector)
POSTGRES_URL=postgresql://user:pass@host/dbname?sslmode=require

# Cloudflare R2 storage
CLOUDFLARE_ACCOUNT_ID=
CF_R2_KEY_ID=
CF_R2_ACCESS_KEY=
R2_EPISODES_PUBLIC_URL=https://your-episodes-bucket.your-domain.com
R2_IMAGES_PUBLIC_URL=https://your-images-bucket.your-domain.com

# Webhook authentication secret (X-Webhook-Secret header)
WEBHOOK_SECRET=your-secret-here

# --- Optional ---

# Email notifications via Resend (pipeline success/failure alerts)
RESEND_API_KEY=
RESEND_SENDER_EMAIL=notifications@yourdomain.com
RESEND_RECIPIENT=you@yourdomain.com

# Vercel deploy hook (triggers website rebuild after episode publication)
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# Publication webhook (notify external systems like n8n when episodes are published)
PUBLICATION_WEBHOOK_URL_PROD=
PUBLICATION_WEBHOOK_URL_TEST=
PUBLICATION_WEBHOOK_SECRET=

# Wasabi archival storage (S3-compatible backup)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=myweirdprompts
WASABI_REGION=eu-central-2
WASABI_ENDPOINT=https://s3.eu-central-2.wasabisys.com

# --- Model Overrides (defaults shown) ---

# TRANSCRIPTION_MODEL=google/gemini-3-flash-preview
# PLANNING_MODEL=google/gemini-3-flash-preview
# SCRIPT_MODEL=google/gemini-3-flash-preview
# METADATA_MODEL=google/gemini-3-flash-preview
# SCRIPT_REVIEW_MODEL=google/gemini-3-flash-preview
# SCRIPT_POLISH_MODEL=google/gemini-3-flash-preview
